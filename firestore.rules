rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }
    
    function isAdmin() {
      return hasRole('admin') || hasRole('super_admin');
    }
    
    function isTeacher() {
      return hasRole('teacher');
    }

    // --- COLLECTIONS ---

    // USERS: 
    // - Everyone can read their own profile.
    // - Admins can read all profiles.
    // - Writes only via Cloud Functions (to ensure role safety).
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Enforce Cloud Functions for data integrity
    }

    // COURSES:
    // - Public Can Read active courses.
    // - Admins/Teachers can write.
    match /courses/{courseId} {
      allow read: if resource.data.isActive == true || isAdmin() || (isTeacher() && resource.data.instructorId == request.auth.uid);
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    // ENROLLMENTS:
    // - User reads own.
    // - Admin reads all.
    // - No client-side writes.
    match /enrollments/{enrollmentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false; // Triggered by payment Cloud Function
    }

    // PAYMENTS:
    // - Strictly private.
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if false;
    }

    // LIVE CLASSES:
    // - Read if enrolled.
    // - Write if teacher/admin.
    match /live_classes/{liveId} {
      allow read: if isAuthenticated(); // More granular check would verify enrollment status
      allow write: if isAdmin() || isTeacher();
    }

    // AUDIT LOGS:
    // - Admin only.
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // DEFAULT: DENY ALL
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
